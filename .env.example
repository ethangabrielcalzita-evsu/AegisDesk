# AegisDesk Environment Variables
# Copy this file to .env and fill in your actual values

# Database Configuration
# For PostgreSQL (Production/Cloud):
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://aegisdesk_user:securepassword@localhost:5432/aegisdesk_db
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/aegisdesk

# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here-generate-a-new-one
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Leave DATABASE_URL commented out to use SQLite for local development
# DATABASE_URL=
